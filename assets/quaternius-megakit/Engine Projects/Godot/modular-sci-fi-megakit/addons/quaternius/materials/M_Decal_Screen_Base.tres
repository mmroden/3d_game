code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_frg_10;
uniform vec4 Color : source_color = vec4(0.511719, 0.013204, 0.000000, 1.000000);
uniform sampler2D tex_frg_6;
uniform sampler2D tex_frg_5;
uniform float Alpha_Scissor = 0.5;



void fragment() {
// Input:11
	float n_out11p0 = TIME;


// FloatOp:12
	float n_in12p1 = 0.10000;
	float n_out12p0 = n_out11p0 * n_in12p1;


// VectorCompose:14
	float n_in14p0 = 0.00000;
	vec2 n_out14p0 = vec2(n_in14p0, n_out12p0);


// UVFunc:13
	vec2 n_in13p1 = vec2(1.00000, 1.00000);
	vec2 n_out13p0 = n_out14p0 * n_in13p1 + UV;


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out13p0);


// ColorParameter:2
	vec4 n_out2p0 = Color;


// VectorOp:15
	vec4 n_out15p0 = n_out10p0 * n_out2p0;


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, UV);


// UVFunc:8
	vec2 n_in8p1 = vec2(2.00000, 2.00000);
	vec2 n_in8p2 = vec2(0.00000, 0.00000);
	vec2 n_out8p0 = (UV - n_in8p2) * n_in8p1 + n_in8p2;


// Texture2D:5
	vec4 n_out5p0 = texture(tex_frg_5, n_out8p0);


// VectorOp:7
	vec4 n_out7p0 = n_out6p0 - n_out5p0;


// Input:19
	float n_out19p0 = TIME;


// FloatOp:20
	float n_in20p1 = 4.00000;
	float n_out20p0 = n_out19p0 * n_in20p1;


// FloatFunc:21
	float n_out21p0 = sin(n_out20p0);


// FloatOp:22
	float n_in22p1 = 4.00000;
	float n_out22p0 = n_out21p0 * n_in22p1;


// Clamp:23
	float n_in23p1 = 0.00000;
	float n_in23p2 = 1.50000;
	float n_out23p0 = clamp(n_out22p0, n_in23p1, n_in23p2);


// Input:18
	vec4 n_out18p0 = COLOR;


// Mix:17
	vec4 n_in17p0 = vec4(1.00000, 1.00000, 1.00000, 1.00000);
	vec4 n_out17p0 = mix(n_in17p0, vec4(n_out23p0), n_out18p0);


// VectorOp:16
	vec4 n_out16p0 = n_out7p0 * n_out17p0;


// FloatConstant:4
	float n_out4p0 = 0.800000;


// FloatConstant:3
	float n_out3p0 = 0.100000;


// FloatParameter:9
	float n_out9p0 = Alpha_Scissor;


// Output:0
	ALBEDO = vec3(n_out15p0.xyz);
	ALPHA = n_out16p0.x;
	ROUGHNESS = n_out4p0;
	SPECULAR = n_out3p0;
	EMISSION = vec3(n_out15p0.xyz);
	ALPHA_SCISSOR_THRESHOLD = n_out9p0;


}
