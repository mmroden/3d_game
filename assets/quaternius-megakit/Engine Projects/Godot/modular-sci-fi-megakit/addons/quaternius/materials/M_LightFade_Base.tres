code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_disabled, diffuse_lambert, specular_schlick_ggx;

uniform sampler2D tex_frg_10;
uniform vec4 Color : source_color = vec4(0.579008, 1.000000, 0.000000, 1.000000);
uniform float FloatParameter = 2.59999990463257;
uniform float Emissive_Intensity = 3;



void fragment() {
// Input:11
	float n_out11p0 = TIME;


// FloatOp:12
	float n_in12p1 = 0.10000;
	float n_out12p0 = n_out11p0 * n_in12p1;


// VectorCompose:14
	float n_in14p0 = 0.00000;
	vec2 n_out14p0 = vec2(n_in14p0, n_out12p0);


// UVFunc:13
	vec2 n_in13p1 = vec2(1.00000, 1.00000);
	vec2 n_out13p0 = n_out14p0 * n_in13p1 + UV;


// UVFunc:21
	vec2 n_in21p1 = vec2(1.00000, 0.20000);
	vec2 n_in21p2 = vec2(0.00000, 0.00000);
	vec2 n_out21p0 = (n_out13p0 - n_in21p2) * n_in21p1 + n_in21p2;


// Texture2D:10
	vec4 n_out10p0 = texture(tex_frg_10, n_out21p0);


// ColorParameter:2
	vec4 n_out2p0 = Color;


// VectorOp:15
	vec4 n_out15p0 = n_out10p0 * n_out2p0;


// Input:16
	vec2 n_out16p0 = UV;


// VectorDecompose:17
	float n_out17p0 = n_out16p0.x;
	float n_out17p1 = n_out16p0.y;


// FloatParameter:19
	float n_out19p0 = FloatParameter;


// FloatOp:18
	float n_out18p0 = n_out17p1 / n_out19p0;


// VectorOp:20
	vec4 n_out20p0 = n_out10p0 * vec4(n_out18p0);


// FloatParameter:23
	float n_out23p0 = Emissive_Intensity;


// VectorOp:22
	vec4 n_out22p0 = n_out15p0 * vec4(n_out23p0);


// Output:0
	ALBEDO = vec3(n_out15p0.xyz);
	ALPHA = n_out20p0.x;
	EMISSION = vec3(n_out22p0.xyz);


}
