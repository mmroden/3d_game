[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform vec4 Color_Base : source_color = vec4(1.000000, 1.000000, 1.000000, 1.000000);
uniform sampler2D Base_Color : source_color;
uniform sampler2D Emissive_Texture;
uniform vec4 Color_Detail : source_color = vec4(1.000000, 0.000000, 0.000000, 1.000000);
uniform sampler2D Detail_Mask;
uniform float Metallic = 1;
uniform sampler2D ORM;
uniform float Roughness = 1;
uniform float Specular = 0;
uniform vec4 Emissive_A : source_color = vec4(1.000000, 0.000000, 0.000000, 1.000000);
uniform vec4 Emissive_B : source_color = vec4(0.000002, 0.668473, 0.211200, 1.000000);
uniform vec4 Emissive_C : source_color = vec4(0.000000, 0.195909, 1.000000, 1.000000);
uniform float Emissive_Intensity = 2;
uniform float Speed = 2;
uniform bool HasBlinking = false;
uniform bool Has_Emissive = false;
uniform sampler2D Normal : hint_normal;



void fragment() {
// ColorParameter:12
	vec4 n_out12p0 = Color_Base;


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(Base_Color, UV);


	vec4 n_out16p0;
// Texture2D:16
	n_out16p0 = texture(Emissive_Texture, UV);


// VectorDecompose:20
	float n_out20p0 = n_out16p0.x;
	float n_out20p1 = n_out16p0.y;
	float n_out20p2 = n_out16p0.z;
	float n_out20p3 = n_out16p0.w;


// VectorOp:48
	vec2 n_out48p0 = vec2(n_out20p0) + vec2(n_out20p1);


// VectorOp:49
	vec2 n_out49p0 = n_out48p0 + vec2(n_out20p2);


// Clamp:50
	float n_in50p1 = 0.00000;
	float n_in50p2 = 1.00000;
	float n_out50p0 = clamp(n_out49p0.x, n_in50p1, n_in50p2);


// Mix:47
	vec4 n_in47p1 = vec4(0.00000, 0.00000, 0.00000, 1.00000);
	vec4 n_out47p0 = mix(n_out2p0, n_in47p1, n_out50p0);


// VectorOp:14
	vec4 n_out14p0 = n_out12p0 * n_out47p0;


// ColorParameter:13
	vec4 n_out13p0 = Color_Detail;


// VectorOp:15
	vec4 n_out15p0 = n_out2p0 * n_out13p0;


	vec4 n_out10p0;
// Texture2D:10
	n_out10p0 = texture(Detail_Mask, UV);


// Mix:11
	vec4 n_out11p0 = mix(n_out14p0, n_out15p0, n_out10p0.x);


// FloatParameter:33
	float n_out33p0 = Metallic;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(ORM, UV);


// VectorDecompose:19
	float n_out19p0 = n_out3p0.x;
	float n_out19p1 = n_out3p0.y;
	float n_out19p2 = n_out3p0.z;
	float n_out19p3 = n_out3p0.w;


// FloatOp:53
	float n_out53p0 = n_out33p0 * n_out19p2;


// FloatParameter:35
	float n_out35p0 = Roughness;


// FloatOp:51
	float n_out51p0 = n_out35p0 * n_out19p1;


// FloatParameter:34
	float n_out34p0 = Specular;


// FloatOp:52
	float n_out52p0 = n_out34p0 * n_out19p1;


// ColorParameter:22
	vec4 n_out22p0 = Emissive_A;


// Mix:21
	vec4 n_in21p0 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_out21p0 = mix(n_in21p0, n_out22p0, n_out20p0);


// ColorParameter:24
	vec4 n_out24p0 = Emissive_B;


// Mix:23
	vec4 n_in23p0 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_out23p0 = mix(n_in23p0, n_out24p0, n_out20p1);


// VectorOp:27
	vec4 n_out27p0 = n_out21p0 + n_out23p0;


// ColorParameter:26
	vec4 n_out26p0 = Emissive_C;


// Mix:25
	vec4 n_in25p0 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_out25p0 = mix(n_in25p0, n_out26p0, n_out20p2);


// VectorOp:28
	vec4 n_out28p0 = n_out27p0 + n_out25p0;


// FloatParameter:31
	float n_out31p0 = Emissive_Intensity;


// Input:39
	float n_out39p0 = TIME;


// FloatParameter:42
	float n_out42p0 = Speed;


// FloatOp:41
	float n_out41p0 = n_out39p0 * n_out42p0;


// FloatFunc:40
	float n_out40p0 = sin(n_out41p0);


// BooleanParameter:43
	bool n_out43p0 = HasBlinking;


// Mix:44
	float n_in44p0 = 1.00000;
	float n_out44p0 = mix(n_in44p0, n_out40p0, (n_out43p0 ? 1.0 : 0.0));


// Clamp:46
	float n_in46p1 = 0.00000;
	float n_in46p2 = 1.00000;
	float n_out46p0 = clamp(n_out44p0, n_in46p1, n_in46p2);


// FloatOp:45
	float n_out45p0 = n_out31p0 * n_out46p0;


// VectorOp:32
	vec4 n_out32p0 = n_out28p0 * vec4(n_out45p0);


// BooleanParameter:29
	bool n_out29p0 = Has_Emissive;


// Mix:30
	vec4 n_in30p0 = vec4(0.00000, 0.00000, 0.00000, 0.00000);
	vec4 n_out30p0 = mix(n_in30p0, n_out32p0, vec4(n_out29p0 ? 1.0 : 0.0));


	vec4 n_out4p0;
// Texture2D:4
	n_out4p0 = texture(Normal, UV);


// Output:0
	ALBEDO = vec3(n_out11p0.xyz);
	METALLIC = n_out53p0;
	ROUGHNESS = n_out51p0;
	SPECULAR = n_out52p0;
	EMISSION = vec3(n_out30p0.xyz);
	AO = n_out19p0;
	NORMAL_MAP = vec3(n_out4p0.xyz);


}
