[resource]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_lambert, specular_schlick_ggx;

uniform float Speed = 2;
uniform float Expansion = 1;
uniform vec4 Color : source_color = vec4(0.596078, 0.741176, 0.423529, 1.000000);
uniform sampler2D tex_frg_6;
uniform sampler2D tex_frg_17;
uniform vec4 Color2 : source_color = vec4(0.117647, 0.152941, 0.070588, 1.000000);
uniform vec4 Emissive : source_color = vec4(0.305882, 0.058823, 0.039216, 1.000000);



void vertex() {
// Input:2
	float n_out2p0 = TIME;


// FloatParameter:5
	float n_out5p0 = Speed;


// FloatOp:4
	float n_out4p0 = n_out2p0 * n_out5p0;


// FloatFunc:3
	float n_out3p0 = sin(n_out4p0);


// FloatParameter:15
	float n_out15p0 = Expansion;


// FloatOp:16
	float n_in16p1 = 0.10000;
	float n_out16p0 = n_out15p0 * n_in16p1;


	float n_out14p0;
// Remap:14
	float n_in14p1 = -1.00000;
	float n_in14p2 = 1.00000;
	float n_in14p3 = 0.00000;
	{
		float __input_range = n_in14p2 - n_in14p1;
		float __output_range = n_out16p0 - n_in14p3;
		n_out14p0 = n_in14p3 + __output_range * ((n_out3p0 - n_in14p1) / __input_range);
	}


// Input:18
	vec4 n_out18p0 = COLOR;


// Mix:17
	float n_in17p0 = 0.00000;
	float n_out17p0 = mix(n_in17p0, n_out14p0, n_out18p0.x);


// Input:10
	vec3 n_out10p0 = NORMAL;


// VectorOp:9
	vec3 n_out9p0 = vec3(n_out17p0) * n_out10p0;


// Input:13
	vec3 n_out13p0 = VERTEX;


// VectorOp:12
	vec3 n_out12p0 = n_out9p0 + n_out13p0;


// Output:0
	VERTEX = n_out12p0;


}

void fragment() {
// ColorParameter:15
	vec4 n_out15p0 = Color;


// ColorConstant:14
	vec4 n_out14p0 = vec4(0.000000, 0.000000, 0.000000, 1.000000);


// Input:8
	float n_out8p0 = TIME;


// FloatOp:9
	float n_in9p1 = 0.50000;
	float n_out9p0 = n_out8p0 * n_in9p1;


// VectorCompose:12
	vec2 n_out12p0 = vec2(n_out9p0, n_out9p0);


// UVFunc:11
	vec2 n_in11p1 = vec2(1.00000, 1.00000);
	vec2 n_out11p0 = n_out12p0 * n_in11p1 + UV;


// Texture2D:6
	vec4 n_out6p0 = texture(tex_frg_6, n_out11p0);


// Mix:13
	vec4 n_out13p0 = mix(n_out15p0, n_out14p0, n_out6p0);


// Input:18
	float n_out18p0 = TIME;


// FloatOp:19
	float n_in19p1 = 0.01000;
	float n_out19p0 = n_out18p0 * n_in19p1;


// VectorCompose:21
	vec2 n_out21p0 = vec2(n_out19p0, n_out19p0);


// UVFunc:22
	vec2 n_in22p1 = vec2(1.00000, 1.00000);
	vec2 n_out22p0 = n_out21p0 * n_in22p1 + UV;


// Texture2D:17
	vec4 n_out17p0 = texture(tex_frg_17, n_out22p0);


// VectorOp:16
	vec4 n_out16p0 = n_out13p0 * n_out17p0;


// ColorParameter:24
	vec4 n_out24p0 = Color2;


// Input:7
	vec4 n_out7p0 = COLOR;


// Mix:23
	vec4 n_out23p0 = mix(n_out16p0, n_out24p0, n_out7p0);


// FloatConstant:4
	float n_out4p0 = 0.000000;


// FloatConstant:3
	float n_out3p0 = 0.500000;


// ColorParameter:2
	vec4 n_out2p0 = Emissive;


// Output:0
	ALBEDO = vec3(n_out23p0.xyz);
	METALLIC = n_out4p0;
	SPECULAR = n_out3p0;
	EMISSION = vec3(n_out2p0.xyz);


}
